llection'], 'description': 'Which tree to browse'}, 'node_id': {'type': 'string', 'description': 'ID of a specific node to inspect. Omit for top-level overview.'}}, 'required': ['tree_type']}}, {'name': 'list_playlists', 'description': 'List all saved playlists with their names, descriptions, and track counts.', 'input_schema': {'type': 'object', 'properties': {}, 'required': []}}, {'name': 'get_playlist_tracks', 'description': 'Get the tracks in a specific playlist by playlist ID.', 'input_schema': {'type': 'object', 'properties': {'playlist_id': {'type': 'string', 'description': 'The playlist ID'}}, 'required': ['playlist_id']}}, {'name': 'list_sets', 'description': 'List all saved DJ sets from the Set Workshop.', 'input_schema': {'type': 'object', 'properties': {}, 'required': []}}, {'name': 'create_playlist', 'description': 'Create a new playlist. Provide either track_ids directly or filters to auto-select matching tracks. Always confirm with the user before creating.', 'input_schema': {'type': 'object', 'properties': {'name': {'type': 'string', 'description': 'Name for the playlist'}, 'description': {'type': 'string', 'description': 'Optional description'}, 'filters': {'type': 'object', 'description': 'Faceted filters to auto-select tracks (same format as search_tracks)', 'properties': {'genres': {'type': 'array', 'items': {'type': 'string'}}, 'mood': {'type': 'array', 'items': {'type': 'string'}}, 'descriptors': {'type': 'array', 'items': {'type': 'string'}}, 'location': {'type': 'array', 'items': {'type': 'string'}}, 'era': {'type': 'array', 'items': {'type': 'string'}}, 'bpm_min': {'type': 'number'}, 'bpm_max': {'type': 'number'}}}, 'track_ids': {'type': 'array', 'items': {'type': 'integer'}, 'description': 'Explicit track IDs to include'}}, 'required': ['name']}}, {'name': 'add_tracks_to_playlist', 'description': 'Add tracks to an existing playlist by playlist ID and track IDs.', 'input_schema': {'type': 'object', 'properties': {'playlist_id': {'type': 'str